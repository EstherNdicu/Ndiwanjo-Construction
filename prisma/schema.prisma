generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Employee {
  id             Int               @id @default(autoincrement())
  name           String
  email          String            @unique
  phone          String?
  role           String
  department     String
  salary         Float?
  employmentType String            @default("monthly")
  createdAt      DateTime          @default(now())
  projects       ProjectEmployee[]
  monthlyPayroll MonthlyPayroll[]
}

model Customer {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  address     String?
  portalToken String?   @unique
  createdAt   DateTime  @default(now())
  projects    Project[]
}

model Project {
  id             Int                @id @default(autoincrement())
  name           String
  description    String?
  status         String             @default("pending")
  startDate      DateTime?
  endDate        DateTime?
  quotation      Float?
  progress       Int                @default(0)
  portalToken    String?            @unique
  customerId     Int?
  customer       Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())
  employees      ProjectEmployee[]
  expenses       Expense[]
  inventory      ProjectInventory[]
  payments       Payment[]
  weeklyPayrolls WeeklyPayroll[]
  equipment      Equipment[]
}

model ProjectEmployee {
  id         Int      @id @default(autoincrement())
  projectId  Int
  employeeId Int
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
}

model Inventory {
  id        Int                @id @default(autoincrement())
  name      String
  quantity  Int
  unit      String?
  price     Float?
  createdAt DateTime           @default(now())
  projects  ProjectInventory[]
}

model ProjectInventory {
  id          Int       @id @default(autoincrement())
  projectId   Int
  inventoryId Int
  quantity    Int       @default(0)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@unique([projectId, inventoryId])
}

model Payment {
  id         Int      @id @default(autoincrement())
  projectId  Int
  amount     Float
  note       String?
  receivedAt DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("viewer")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Float
  category    String?
  projectName String?
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model WeeklyPayroll {
  id           Int      @id @default(autoincrement())
  projectId    Int
  foremanName  String
  numWorkers   Int
  dailyRate    Float
  daysWorked   Float
  totalAmount  Float
  weekStart    DateTime
  weekEnd      DateTime
  note         String?
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MonthlyPayroll {
  id         Int      @id @default(autoincrement())
  employeeId Int
  month      Int
  year       Int
  amount     Float
  paid       Boolean  @default(false)
  paidAt     DateTime?
  note       String?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
}

model Activity {
  id          Int      @id @default(autoincrement())
  description String
  bold        String?
  createdAt   DateTime @default(now())
}

model Equipment {
  id              Int              @id @default(autoincrement())
  name            String
  type            String
  status          String           @default("available")
  projectId       Int?
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  purchaseDate    DateTime?
  purchaseCost    Float?
  notes           String?
  createdAt       DateTime         @default(now())
  maintenanceLogs MaintenanceLog[]
}

model MaintenanceLog {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  description String
  cost        Float?
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

model Supplier {
  id          Int                @id @default(autoincrement())
  name        String
  contact     String?
  email       String?
  phone       String?
  materials   String?
  creditTerms String?
  createdAt   DateTime           @default(now())
  purchases   SupplierPurchase[]
}

model SupplierPurchase {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  description String
  amount      Float
  paid        Boolean  @default(false)
  paidAt      DateTime?
  projectId   Int?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}